# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Razorpay payment gateway (required for Proceed to pay).
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxx"
# INR (default) or USD if your Razorpay account supports it
RAZORPAY_CURRENCY="INR"

# Public site URL for SEO canonicals, Open Graph, and sitemap (no trailing slash).
# Example: https://www.yourdomain.com
VITE_SITE_URL="https://productstudio.app"

# ---- Supabase (Auth + Database + Storage) ----
# Dashboard → Project Settings → API
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="your_anon_public_jwt"

# Server-only (Express). Never expose the service role key to the browser.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_secret_key"

# Optional: Supabase CLI / Edge Function deploy
# SUPABASE_ACCESS_TOKEN="sbp_..."
# SUPABASE_PROJECT_REF="your_project_ref"

# Edge Functions base (optional — Express /api/billing also works)
# https://YOUR_PROJECT.supabase.co/functions/v1/apply-plan
# https://YOUR_PROJECT.supabase.co/functions/v1/consume-tokens
# https://YOUR_PROJECT.supabase.co/functions/v1/me
# https://YOUR_PROJECT.supabase.co/functions/v1/update-fx-rates

# Gemini (required for generation)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ExchangeRate-API (server-only — Edge Function update-fx-rates)
# EXCHANGE_RATE_API_KEY="your_exchangerate_api_key"
# FX_CRON_SECRET="random_shared_secret"

# Resend SMTP for Supabase Auth OTP emails (configure in Dashboard or Management API)
# Host: smtp.resend.com | Port: 465 | User: resend | Pass: API key
# RESEND_API_KEY="re_xxxxxxxx"
# Sender must be a verified domain in Resend (e.g. info@codewix.in)

