# GEMINI_API_KEY: Required for Gemini AI API calls (Express server only).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public site URL for SEO canonicals / Open Graph (no trailing slash).
VITE_SITE_URL="https://www.codewix.in"

# Optional: absolute base for Express /api when SPA is on Amplify and API elsewhere.
# Example: https://api.your-node-host.com
# VITE_API_URL=""

# ---- Supabase (Auth + Database + Storage) ----
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="your_anon_public_jwt"

# Server-only (Express). Never expose the service role key to the browser.
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_secret_key"

# Optional: Supabase CLI / Edge Function deploy
# SUPABASE_ACCESS_TOKEN="sbp_..."
# SUPABASE_PROJECT_REF="your_project_ref"

# Razorpay (Express + Edge Functions create-razorpay-order / confirm-razorpay-payment)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxx"
RAZORPAY_CURRENCY="INR"

# ExchangeRate-API (server-only — Edge Function update-fx-rates)
# EXCHANGE_RATE_API_KEY="your_exchangerate_api_key"
# FX_CRON_SECRET="random_shared_secret"

# Resend SMTP for Supabase Auth OTP (Dashboard)
# RESEND_API_KEY="re_xxxxxxxx"
